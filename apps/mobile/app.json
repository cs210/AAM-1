{
  "expo": {
    "name": "Museum&",
    "slug": "museumand",
    "version": "0.0.1",
    "orientation": "portrait",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/1cb3ee35-380a-43d7-a054-786cbb3c8445"
    },
    "icon": "./assets/images/icon.png",
    "scheme": "yami",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sh.edm.museum",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "sh.edm.museum"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "$(PRODUCT_NAME) uses your location to show museums near you and sort by distance.",
          "locationAlwaysAndWhenInUsePermission": "$(PRODUCT_NAME) uses your location to show museums near you and sort by distance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1cb3ee35-380a-43d7-a054-786cbb3c8445"
      }
    },
    "owner": "yami-mobile"
  }
}
